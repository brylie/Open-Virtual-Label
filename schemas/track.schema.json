{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://openvirtuallabel.org/schemas/track/v1",
    "title": "Track",
    "description": "A single track within a release. Covers identity, rights, files, mastering measurements, and QC status.",
    "type": "object",
    "required": [
        "id",
        "release_id",
        "title",
        "position",
        "schema_version"
    ],
    "additionalProperties": false,
    "properties": {
        "schema_version": {
            "type": "string",
            "const": "1"
        },
        "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "maxLength": 64,
            "description": "Slug. e.g. 'chromatic-drift'. Must be unique within the release."
        },
        "release_id": {
            "type": "string",
            "description": "References a release.json id."
        },
        "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
        },
        "position": {
            "type": "integer",
            "minimum": 1,
            "description": "Track number within the release. Must be unique within the release."
        },
        "duration_seconds": {
            "type": [
                "integer",
                "null"
            ],
            "minimum": 1,
            "description": "Track duration in seconds. Populated after export."
        },
        "isrc": {
            "type": [
                "string",
                "null"
            ],
            "pattern": "^[A-Z]{2}-?[A-Z0-9]{3}-?[0-9]{2}-?[0-9]{5}$",
            "description": "International Standard Recording Code. Format: CC-XXX-YY-NNNNN."
        },
        "iswc": {
            "type": [
                "string",
                "null"
            ],
            "pattern": "^T-[0-9]{9}-[0-9]$",
            "description": "International Standard Musical Work Code. Assigned by PRO for the composition."
        },
        "musical_key": {
            "type": [
                "string",
                "null"
            ],
            "description": "Key of the track. e.g. 'C minor', 'F# major'. Optional but useful for sync licensing."
        },
        "bpm": {
            "type": [
                "number",
                "null"
            ],
            "minimum": 1,
            "description": "Beats per minute. Optional; many ambient tracks have no fixed BPM."
        },
        "collaborators": {
            "type": "array",
            "description": "All contributors and their rights splits. Splits must sum to 100 across all collaborator entries for a given role.",
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "role",
                    "split_percentage"
                ],
                "additionalProperties": false,
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Display name of the contributor."
                    },
                    "artist_id": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "References an artist.json id if this contributor is also an OVL artist."
                    },
                    "role": {
                        "type": "string",
                        "enum": [
                            "composer",
                            "lyricist",
                            "producer",
                            "performer",
                            "arranger",
                            "mixer",
                            "mastering-engineer",
                            "remixer",
                            "featured-artist",
                            "session-musician"
                        ]
                    },
                    "split_percentage": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100,
                        "description": "Percentage of rights for this role. Must sum to 100 across all entries sharing the same role."
                    },
                    "pro": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "This contributor's PRO. e.g. 'ASCAP', 'PRS'."
                    },
                    "ipi_number": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                }
            }
        },
        "files": {
            "type": "object",
            "additionalProperties": false,
            "description": "Paths to all file assets for this track, relative to the release directory.",
            "properties": {
                "master_wav": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Lossless master WAV. The source of record for archival and distribution."
                },
                "stems_zip": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "ZIP archive of stems. Named stems preferred over a flat mix."
                },
                "project_file": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "DAW session/project file. e.g. 'sessions/track-01.cpr' or 'sessions/track-01.als'."
                },
                "mp3_320": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "320kbps MP3 for preview or non-lossless delivery contexts."
                },
                "wav_for_distribution": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Distribution-ready WAV (24-bit / 44.1kHz unless distributor requires otherwise). May differ from master if dithering applied."
                }
            }
        },
        "mastering": {
            "type": "object",
            "additionalProperties": false,
            "description": "Mastering measurements and session record. Populated by the Mastering Companion agent.",
            "properties": {
                "profile_id": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "References a mastering_profile.json id. Overrides the release-level mastering_profile_id if set."
                },
                "integrated_lufs": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Integrated loudness of the mastered file in LUFS."
                },
                "true_peak_dbtp": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "True peak level in dBTP."
                },
                "lra": {
                    "type": [
                        "number",
                        "null"
                    ],
                    "description": "Loudness Range in LU."
                },
                "sample_rate_hz": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Sample rate of the mastered file. e.g. 44100, 48000, 96000."
                },
                "bit_depth": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "enum": [
                        16,
                        24,
                        32
                    ],
                    "description": "Bit depth of the mastered file."
                },
                "mastered_date": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "format": "date"
                },
                "mastered_by": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Name or identifier of who performed mastering."
                },
                "notes": {
                    "type": "string",
                    "description": "Session notes appended by the Mastering Companion. May include rationale for any deviation from target profile."
                }
            }
        },
        "qc": {
            "type": "object",
            "additionalProperties": false,
            "description": "Track-level QC status. Set by the QC agent.",
            "properties": {
                "passed": {
                    "type": "boolean",
                    "default": false
                },
                "checked_date": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "format": "date"
                },
                "failures": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "List of QC check failures. Empty if passed."
                },
                "override": {
                    "type": "object",
                    "additionalProperties": false,
                    "description": "If an artist overrides a QC failure, the reason must be recorded here.",
                    "properties": {
                        "overridden_by": {
                            "type": "string"
                        },
                        "date": {
                            "type": "string",
                            "format": "date"
                        },
                        "reason": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "notes": {
            "type": "string",
            "description": "Free-form internal notes. Not published."
        }
    }
}