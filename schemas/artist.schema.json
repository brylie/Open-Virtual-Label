{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://openvirtuallabel.org/schemas/artist/v1",
    "title": "Artist",
    "description": "Artist identity, platform presence, rights registration, and distribution configuration.",
    "type": "object",
    "required": [
        "id",
        "display_name",
        "default_license",
        "schema_version"
    ],
    "additionalProperties": false,
    "properties": {
        "schema_version": {
            "type": "string",
            "const": "1"
        },
        "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "maxLength": 64,
            "description": "Slug. Must match the artist's subdirectory name under workspace/artists/."
        },
        "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Primary performing name used on releases and public profiles."
        },
        "legal_name": {
            "type": "string",
            "maxLength": 256,
            "description": "Full legal name. Used for contracts, rights registration, and tax documents. Not published."
        },
        "also_known_as": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Additional performing names or project aliases (e.g. a solo ambient project and an electronic alias)."
        },
        "members": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Artist IDs of individual members, for collaborative projects and bands."
        },
        "bio": {
            "type": "object",
            "additionalProperties": false,
            "description": "Bio text in multiple lengths for different contexts.",
            "properties": {
                "short": {
                    "type": "string",
                    "maxLength": 280,
                    "description": "One or two sentences. For social profiles and streaming bios."
                },
                "medium": {
                    "type": "string",
                    "maxLength": 1024,
                    "description": "One paragraph. For press kits and Bandcamp artist page."
                },
                "full": {
                    "type": "string",
                    "description": "Full bio. For website and detailed press materials."
                }
            }
        },
        "genre_tags": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "minItems": 1,
            "description": "Primary genre tags used for distribution metadata and outreach targeting."
        },
        "contact": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Public or licensing contact email."
                },
                "website": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "location": {
            "type": "string",
            "description": "City and country. Used for press kits and venue outreach."
        },
        "rights": {
            "type": "object",
            "additionalProperties": false,
            "description": "Performing rights and publishing registration.",
            "properties": {
                "pro": {
                    "type": "string",
                    "description": "Performing rights organisation. e.g. 'Teosto', 'ASCAP', 'PRS', 'SOCAN'."
                },
                "ipi_number": {
                    "type": "string",
                    "description": "IPI (Interested Party Information) number assigned by PRO."
                },
                "isni": {
                    "type": "string",
                    "description": "International Standard Name Identifier."
                }
            }
        },
        "distribution": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "distributor": {
                    "type": "string",
                    "description": "Primary distribution platform. e.g. 'amuse', 'distrokid', 'cdbaby', 'tunecore'."
                },
                "distributor_artist_id": {
                    "type": "string",
                    "description": "Artist identifier within the distribution platform, if applicable."
                }
            }
        },
        "default_license": {
            "type": "string",
            "minLength": 1,
            "description": "Default license for this artist's releases. Overrides label default. e.g. 'CC BY 4.0'."
        },
        "platforms": {
            "type": "object",
            "additionalProperties": false,
            "description": "Platform-specific identifiers. All fields optional — populate as accounts are created.",
            "properties": {
                "spotify_artist_id": {
                    "type": "string"
                },
                "apple_music_artist_id": {
                    "type": "string"
                },
                "youtube_channel_id": {
                    "type": "string"
                },
                "youtube_music_artist_id": {
                    "type": "string"
                },
                "bandcamp_url": {
                    "type": "string",
                    "format": "uri"
                },
                "soundcloud_url": {
                    "type": "string",
                    "format": "uri"
                },
                "instagram_handle": {
                    "type": "string"
                },
                "facebook_url": {
                    "type": "string",
                    "format": "uri"
                },
                "tiktok_handle": {
                    "type": "string"
                },
                "subvert_fm_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Artist profile on Subvert.fm co-op music platform"
                },
                "fma_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Artist page on Free Music Archive"
                }
            }
        },
        "created_date": {
            "type": "string",
            "format": "date"
        }
    }
}