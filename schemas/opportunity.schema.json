{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://openvirtuallabel.org/schemas/opportunity/v1",
    "title": "Opportunity",
    "description": "A single outreach or licensing opportunity in the CRM pipeline. Created and maintained by the Outreach / CRM agent. Never advanced to 'sent' status without explicit artist approval.",
    "type": "object",
    "required": [
        "id",
        "type",
        "status",
        "contact",
        "schema_version"
    ],
    "additionalProperties": false,
    "properties": {
        "schema_version": {
            "type": "string",
            "const": "1"
        },
        "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "maxLength": 64,
            "description": "Slug. e.g. 'calm-waters-podcast-2025-06'."
        },
        "type": {
            "type": "string",
            "enum": [
                "sync-license",
                "commission",
                "playlist-pitch",
                "collaboration",
                "performance",
                "press",
                "other"
            ],
            "description": "Category of opportunity. Determines which workflow and outreach templates apply."
        },
        "status": {
            "type": "string",
            "enum": [
                "identified",
                "researched",
                "draft-ready",
                "approved",
                "sent",
                "follow-up",
                "responded",
                "won",
                "lost",
                "declined",
                "stale"
            ],
            "description": "Pipeline stage. 'draft-ready' means outreach is prepared and awaiting artist approval. 'approved' means artist has approved the draft. Status must not advance from 'approved' to 'sent' without a logged approval entry in outreach_history."
        },
        "artist_id": {
            "type": "string",
            "description": "References the artist this opportunity is for."
        },
        "contact": {
            "type": "object",
            "required": [
                "name"
            ],
            "additionalProperties": false,
            "description": "The person or entity being contacted.",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Full name or organisation name."
                },
                "role": {
                    "type": "string",
                    "description": "e.g. 'Podcast producer', 'Indie game developer', 'Playlist curator'."
                },
                "email": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "format": "email"
                },
                "url": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "format": "uri",
                    "description": "Podcast page, YouTube channel, game page, or other primary URL."
                },
                "social_handles": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "description": "Platform handles. Keys are platform names e.g. 'instagram', 'twitter'."
                },
                "notes": {
                    "type": "string",
                    "description": "Research notes about this contact — their audience, style, past music use, anything that makes outreach more personal."
                }
            }
        },
        "match": {
            "type": "object",
            "additionalProperties": false,
            "description": "Assessment of how well this opportunity fits the artist.",
            "properties": {
                "score": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "description": "1–10 fit score. 8+ means pursue; 5–7 means pursue if capacity allows; below 5 means low priority."
                },
                "rationale": {
                    "type": "string",
                    "description": "Why this score was assigned. Should reference specific evidence: audience alignment, past music use, stated needs."
                }
            }
        },
        "tracks_suggested": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Track IDs suggested for this opportunity. Populated by the CRM agent during research."
        },
        "value_estimate": {
            "type": "object",
            "additionalProperties": false,
            "description": "Estimated financial value, if applicable. For non-revenue opportunities (community performance, CC placement), omit.",
            "properties": {
                "amount": {
                    "type": "number",
                    "minimum": 0
                },
                "currency": {
                    "type": "string",
                    "default": "EUR"
                },
                "basis": {
                    "type": "string",
                    "description": "How the estimate was reached. e.g. 'Flat fee per episode', 'Per-minute sync rate based on market research'."
                }
            }
        },
        "outreach_history": {
            "type": "array",
            "description": "Chronological log of all actions taken on this opportunity.",
            "items": {
                "type": "object",
                "required": [
                    "date",
                    "action"
                ],
                "additionalProperties": false,
                "properties": {
                    "date": {
                        "type": "string",
                        "format": "date"
                    },
                    "action": {
                        "type": "string",
                        "enum": [
                            "identified",
                            "researched",
                            "draft-created",
                            "draft-approved",
                            "draft-edited",
                            "sent",
                            "follow-up-sent",
                            "response-received",
                            "meeting-scheduled",
                            "won",
                            "lost",
                            "declined",
                            "stale-flagged"
                        ]
                    },
                    "note": {
                        "type": "string",
                        "description": "Details about this action. For 'response-received', summarise the response."
                    },
                    "approved_by": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "For 'draft-approved' and 'sent' actions: who approved. Should be artist name or identifier."
                    },
                    "follow_up_due": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date",
                        "description": "If a follow-up is triggered by this action, the date it is due."
                    }
                }
            }
        },
        "follow_up_due": {
            "type": [
                "string",
                "null"
            ],
            "format": "date",
            "description": "Next follow-up date, if any. Surfaced by the CRM agent in status summaries. Redundant with outreach_history but maintained as a top-level field for quick access."
        },
        "created_date": {
            "type": "string",
            "format": "date"
        },
        "notes": {
            "type": "string",
            "description": "Additional internal notes. Not included in any outreach."
        }
    }
}